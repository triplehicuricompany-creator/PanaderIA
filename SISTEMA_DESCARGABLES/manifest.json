  "archivos_control": [
    "README.md",
    "checklists.md",
    "plantillas.md",
    "formatos.md",
    "hojas_trabajo.md",
    "evaluaciones.md",
    "certificados.md",
    "nomenclatura.md",
    "control_calidad.md"
  ],
  "reglas_actualizacion": {
    "versionado": "SemVer editorial: mayor.menor.parche",
