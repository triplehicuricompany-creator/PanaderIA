    "certificado",
    "guia_auxiliar",
    "tabla_referencia"
  ],
  "formatos_permitidos": [
    "PDF",
    "DOCX",
    "XLSX",
    "CSV",
    "PPTX",
    "PNG",
    "SVG",
    "MD"
